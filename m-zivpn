#!/bin/bash
# =========================================================
# PREMIUM INTERACTIVE INTERFACE MENU MANAGER V4 HYBRID
# Location: /usr/bin/m-zivpn (Simpan & upload ke GitHub)
# =========================================================

DB_JSON="/etc/limit/zivpn/database.json"

format_bytes() {
    local bytes=$1
    if [ -z "$bytes" ] || [ "$bytes" -lt 0 ] 2>/dev/null; then bytes=0; fi
    if (( bytes >= 1073741824 )); then
        echo -e "$(printf "%.2f" $(echo "scale=2; $bytes/1073741824" | bc)) GB"
    elif (( bytes >= 1048576 )); then
        echo -e "$(printf "%.2f" $(echo "scale=2; $bytes/1048576" | bc)) MB"
    else
        echo -e "${bytes} Bytes"
    fi
}

select_user_hybrid() {
    local prompt_msg=$1
    if [ ! -f "$DB_JSON" ] || [ "$(jq 'keys | length' $DB_JSON 2>/dev/null)" -eq 0 ]; then
        echo "EMPTY"; return
    fi
    mapfile -t user_list < <(jq -r 'keys[]' "$DB_JSON" 2>/dev/null)
    echo -e "No.  Username       Status        Expired"
    echo -e "──────────────────────────────────────────────────"
    for i in "${!user_list[@]}"; do
        status=$(jq -r --arg u "${user_list[$i]}" '.[$u].status' "$DB_JSON")
        exp=$(jq -r --arg u "${user_list[$i]}" '.[$u].expired_date' "$DB_JSON")
        if [[ "$status" == "ACTIVE" ]]; then
            status_col="\033[1;32m$status\033[0m"
        else
            status_col="\033[1;31m$status\033[0m"
        fi
        printf " [%02d] %-14s %-22b %s\n" "$((i+1))" "${user_list[$i]}" "$status_col" "$exp"
    done
    echo -e "──────────────────────────────────────────────────"
    read -p "$prompt_msg" target_input
    local selected_user=""
    if [[ "$target_input" =~ ^[0-9]+$ ]] && [ "$target_input" -le "${#user_list[@]}" ] && [ "$target_input" -gt 0 ]; then
        selected_user="${user_list[$((target_input-1))]}"
    else
        selected_user=$(echo "$target_input" | tr -d '[:space:]')
    fi
    if [[ -z "$selected_user" ]] || ! jq -e --arg u "$selected_user" '.[$u]' "$DB_JSON" >/dev/null 2>&1; then
        echo "NOT_FOUND"
    else
        echo "$selected_user"
    fi
}

clear
echo -e "──────────────────────────────────────"
echo -e "         PREMIUM ZIVPN MANAGER        "
echo -e "──────────────────────────────────────"
echo -e " Engine : Hybrid Core V4 Full Dual-Input"
echo -e "──────────────────────────────────────"
echo -e " [01] Create Account Premium"
echo -e " [02] Trial Account"
echo -e " [03] Renew Account"
echo -e " [04] Delete Account"
echo -e " ──────────────────────────────────────"
echo -e " [05] Check Login"
echo -e " [06] List Member"
echo -e " [07] Delete Expired"
echo -e " [08] Lock Account"
echo -e " [09] Unlock Account"
echo -e " [10] List User Locked"
echo -e " ──────────────────────────────────────"
echo -e " [11] Detail Account"
echo -e " [12] Change Limit IP"
echo -e " [13] Change Limit Quota"
echo -e "──────────────────────────────────────"
read -p "Pilih Menu : " menu_choice

case "$menu_choice" in
    01|1)
        clear
        echo -e "➜ Create Account Premium Custom"
        read -p " ➜ Masukkan Username Baru : " username
        username=$(echo "$username" | tr -d '[:space:]')
        if [ -z "$username" ]; then echo "❌ Gagal: Username kosong!"; exit 1; fi
        read -p " ➜ Durasi Masa Aktif (Hari) [Kosongkan = 30]: " masa_aktif
        if [[ ! "$masa_aktif" =~ ^[0-9]+$ ]]; then masa_aktif=30; fi
        read -p " ➜ Batasan Multi-IP (Device) [Kosongkan = 2]: " limit_ip
        if [[ ! "$limit_ip" =~ ^[0-9]+$ ]]; then limit_ip=2; fi
        read -p " ➜ Total Limit Kuota Data (GB) [Kosongkan = 10]: " limit_gb
        if [[ ! "$limit_gb" =~ ^[0-9]+$ ]]; then limit_gb=10; fi
        
        /usr/local/bin/mzivpn add "$username" "$masa_aktif" "$limit_ip" "$limit_gb"
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "\033[1;92m✔ Sukses: User '$username' Aktif $masa_aktif Hari, Limit $limit_ip IP, Kuota $limit_gb GB!\033[0m"
        ;;
        
    02|2)
        clear
        trial_user="trial$(echo $RANDOM | cut -c1-3)"
        /usr/local/bin/mzivpn add "$trial_user" "1" "2" "10"
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "\033[1;92m✔ Akun Trial Dibuat: '$trial_user' (1 Hari, 2 IP, 10GB Data)!\033[0m"
        ;;
        
    03|3)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih User yang akan di-Renew: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo "❌ Gagal mendeteksi user."; exit 1; fi
        read -p " ➜ Tambah Waktu Berapa Hari?: " tambah_hari
        /usr/local/bin/mzivpn renew "$user_target" "$tambah_hari"
        systemctl restart zivpn >/dev/null 2>&1
        echo "✔ Akun berhasil diperpanjang!"
        ;;
        
    04|4)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih Akun yang akan Dihapus: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo "❌ Gagal."; exit 1; fi
        /usr/local/bin/mzivpn del "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        echo "✔ Sukses dihapus total!"
        ;;
        
    05|5)
        clear
        echo -e "=================================================="
        echo -e "     CHECK REALTIME LOGIN USER PORT 5667          "
        echo -e "=================================================="
        # Menampilkan IP yang sedang terkoneksi langsung ke ZIVPN
        netstat -anp | grep :5667 | grep ESTABLISHED | awk '{print $5}' | cut -d: -f1 | sort | uniq -c | while read count ip; do
            echo -e " ➜ Terdeteksi IP: \033[1;36m$ip\033[0m aktif sebanyak \033[1;33m$count\033[0m koneksi."
        done
        echo -e "=================================================="
        ;;
        
    06|6)
        clear
        /usr/local/bin/mzivpn list
        ;;
        
    07|7)
        clear
        echo "➜ Membersihkan akun expired & kuota habis..."
        /usr/local/bin/mzivpn clean_exp
        systemctl restart zivpn >/dev/null 2>&1
        ;;
        
    08|8)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih Akun untuk di-Lock Manual: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        /usr/local/bin/mzivpn lock "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        echo "✔ Akun berhasil dikunci manual."
        ;;
        
    09|9)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih Akun untuk di-Unlock: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        /usr/local/bin/mzivpn unlock "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        echo "✔ Akun berhasil dibuka kembali."
        ;;
        
    10)
        clear
        echo -e "=================================================="
        echo -e "         DAFTAR MEMBER YANG SEDANG TERKUNCI       "
        echo -e "=================================================="
        if [ ! -f "$DB_JSON" ]; then echo "Kosong."; else
            jq -r 'to_entries[] | select(.value.status == "LOCKED") | " ➜ \(.key) (Kunci Sampai: \(.value.lock_until))"' "$DB_JSON"
        fi
        echo -e "=================================================="
        ;;
        
    11)
        clear
        user_target=$(select_user_hybrid " ➜ Lihat Detail Akun: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        st=$(jq -r --arg u "$user_target" '.[$u].status' "$DB_JSON")
        ex=$(jq -r --arg u "$user_target" '.[$u].expired_date' "$DB_JSON")
        ipl=$(jq -r --arg u "$user_target" '.[$u].limit_ip' "$DB_JSON")
        uq=$(jq -r --arg u "$user_target" '.[$u].usage_quota' "$DB_JSON")
        lq=$(jq -r --arg u "$user_target" '.[$u].limit_quota' "$DB_JSON")
        lku=$(jq -r --arg u "$user_target" '.[$u].lock_until' "$DB_JSON")
        if [[ "$st" == "ACTIVE" ]]; then st_col="\033[1;32m$st\033[0m"; else st_col="\033[1;31m$st\033[0m"; fi
        echo "=================================================="
        echo "  Username         : $user_target"
        echo "  Status           : $st_col"
        echo "  Expired          : $ex"
        echo "  Limit Multi-IP   : $ipl IP"
        echo "  Kuota Terpakai   : $(format_bytes $uq) / $(format_bytes $lq)"
        [ ! -z "$lku" ] && echo "  Banned Sampai    : $lku"
        echo "=================================================="
        ;;
        
    12)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih User Ubah IP: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        read -p " ➜ Ketik Limit IP Baru: " new_ip
        /usr/local/bin/mzivpn ch_ip "$user_target" "$new_ip"
        echo "✔ Limit IP berhasil diperbarui."
        ;;
        
    13)
        clear
        user_target=$(select_user_hybrid " ➜ Pilih User Ubah Kuota: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        read -p " ➜ Masukkan Limit Kuota Baru (GB): " new_quota
        /usr/local/bin/mzivpn ch_quota "$user_target" "$new_quota"
        systemctl restart zivpn >/dev/null 2>&1
        echo "✔ Limit Kuota berhasil diperbarui."
        ;;
        
    *)
        echo "❌ Salah input!"
        exit 1
        ;;
esac
