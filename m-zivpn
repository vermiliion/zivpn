#!/bin/bash
# =========================================================
# PREMIUM INTERACTIVE INTERFACE MENU MANAGER FOR ZIVPN
# Location: /usr/bin/m-zivpn
# =========================================================

DB_JSON="/etc/limit/zivpn/database.json"

clear
echo -e "\033[1;36m==================================================\033[0m"
echo -e "\033[1;33m          MENU UTAMA PREMIUM ZIVPN MANAGER        \033[0m"
echo -e "\033[1;36m==================================================\033[0m"
echo -e " [1] Tambah Akun Baru (Add User)"
echo -e " [2] Hapus Akun ZIVPN (Delete User)"
echo -e " [3] Cek Daftar Semua Akun (List Users)"
echo -e " [4] Cek Status Service Core ZIVPN"
echo -e " [5] Keluar (Exit)"
echo -e "\033[1;36m==================================================\033[0m"
read -p " ➜ Masukkan pilihan maseee [1-5]: " menu_choice

if [[ "$menu_choice" == "1" ]]; then
    clear
    echo -e "\033[1;36m==================================================\033[0m"
    echo -e "\033[1;33m               TAMBAH AKUN BARU ZIVPN             \033[0m"
    echo -e "\033[1;36m==================================================\033[0m"
    read -p " ➜ Masukkan Nama Username: " username
    username=$(echo "$username" | tr -d '[:space:]')
    
    if [[ -z "$username" ]]; then
        echo -e "\033[1;31m❌ Nama username tidak boleh kosong maseee!\033[0m"
        exit 1
    fi
    
    # Memanggil Backend Engine Python untuk Inject Akun
    /usr/local/bin/mzivpn add "$username"
    
    # Restart core service agar config.json terbaru langsung dibaca biner
    systemctl restart zivpn >/dev/null 2>&1
    
    echo -e "\033[1;92m✔ Akun '$username' sukses dibuat dan disinkronkan!\033[0m"

elif [[ "$menu_choice" == "2" ]]; then
    clear
    echo -e "\033[1;36m==================================================\033[0m"
    echo -e "\033[1;31m                 HAPUS AKUN ZIVPN                 \033[0m"
    echo -e "\033[1;36m==================================================\033[0m"
    
    # Mengambil daftar akun aktif dari database secara berurutan
    if [ ! -f "$DB_JSON" ] || [ "$(jq 'keys | length' $DB_JSON 2>/dev/null)" -eq 0 ]; then
        echo -e "\033[1;31m❌ Belum ada akun yang terdaftar di database maseee.\033[0m"
        exit 1
    fi
    
    echo -e "No.  Username       Status"
    echo -e "--------------------------------------------------"
    mapfile -t user_list < <(jq -r 'keys[]' "$DB_JSON" 2>/dev/null)
    
    for i in "${!user_list[@]}"; do
        status=$(jq -r --arg u "${user_list[$i]}" '.[$u].status' "$DB_JSON")
        printf " [%02d] %-14s %s\n" "$((i+1))" "${user_list[$i]}" "$status"
    done
    echo -e "--------------------------------------------------"
    read -p " ➜ Masukkan Nomor atau Nama Akun: " target_input
    
    # Validasi input apakah berupa nomor indeks atau string teks langsung
    if [[ "$target_input" =~ ^[0-9]+$ ]] && [ "$target_input" -le "${#user_list[@]}" ] && [ "$target_input" -gt 0 ]; then
        selected_user="${user_list[$((target_input-1))]}"
    else
        selected_user=$(echo "$target_input" | tr -d '[:space:]')
    fi
    
    if [[ -z "$selected_user" ]] || ! jq -e --arg u "$selected_user" '.[$u]' "$DB_JSON" >/dev/null 2>&1; then
        echo -e "\033[1;31m❌ Akun tidak ditemukan maseee!\033[0m"
        exit 1
    fi
    
    # Memanggil Backend Engine Python untuk Menghapus Akun
    /usr/local/bin/mzivpn del "$selected_user"
    
    # Restart core service agar config.json terbaru langsung dibaca biner
    systemctl restart zivpn >/dev/null 2>&1
    
    echo -e "\033[1;92m✔ Akun $selected_user sukses dihapus dari sistem!\033[0m"

elif [[ "$menu_choice" == "3" ]]; then
    clear
    echo -e "\033[1;36m==================================================\033[0m"
    echo -e "\033[1;32m                 DAFTAR AKUN ZIVPN                \033[0m"
    echo -e "\033[1;36m==================================================\033[0m"
    if [ -f "$DB_JSON" ]; then
        jq -r 'keys[]' "$DB_JSON" 2>/dev/null
    else
        echo "Database kosong."
    fi
    echo -e "\033[1;36m==================================================\033[0m"

elif [[ "$menu_choice" == "4" ]]; then
    clear
    systemctl status zivpn

else
    echo "Keluar..."
    exit 0
fi