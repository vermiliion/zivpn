#!/bin/bash
# =========================================================
# PREMIUM INTERACTIVE INTERFACE MENU MANAGER V4 HYBRID
# Location: /usr/bin/m-zivpn (The Unified Master Script)
# Features: Real-time Monitor, Auto Quota & Cloud Backup Bot
# =========================================================

DB_JSON="/etc/limit/zivpn/database.json"
BACKUP_DIR="/etc/limit/zivpn/backup"
MYIP=$(curl -sS ipv4.icanhazip.com 2>/dev/null || wget -qO- icanhazip.com)
dateToday=$(date +"%Y-%m-%d")

mkdir -p "$BACKUP_DIR"

# --- DEFINISI WARNA PREMIUM ---
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
PURPLE='\033[1;35m'
CYAN='\033[1;36m'
LIGHT='\033[1;37m'
NC='\033[0m'
BIWhite='\033[1;97m'

# Pastikan jq terinstall untuk parsing database json
if ! command -v jq &> /dev/null; then
    apt-get update && apt-get install -y jq >/dev/null 2>&1
fi

format_bytes() {
    local bytes=$1
    if [ -z "$bytes" ] || [ "$bytes" == "null" ] || [ "$bytes" -lt 0 ] 2>/dev/null; then bytes=0; fi
    if (( bytes >= 1073741824 )); then
        echo -e "${CYAN}$(printf "%.2f" $(echo "scale=2; $bytes/1073741824" | bc)) GB${NC}"
    elif (( bytes >= 1048576 )); then
        echo -e "${YELLOW}$(printf "%.2f" $(echo "scale=2; $bytes/1048576" | bc)) MB${NC}"
    else
        echo -e "${LIGHT}${bytes} Bytes${NC}"
    fi
}

select_user_hybrid() {
    local prompt_msg=$1
    if [ ! -f "$DB_JSON" ] || [ "$(jq 'keys | length' $DB_JSON 2>/dev/null)" -eq 0 ]; then
        echo "EMPTY"
        return
    fi
    mapfile -t user_list < <(jq -r 'keys[]' "$DB_JSON" 2>/dev/null)
    
    echo -e "${YELLOW}No.  Username       Status        Expired${NC}" >&2
    echo -e "${BLUE}──────────────────────────────────────────────────${NC}" >&2
    for i in "${!user_list[@]}"; do
        local user_name="${user_list[$i]}"
        status=$(jq -r --arg u "$user_name" '.[$u].status // "UNKNOWN"' "$DB_JSON")
        exp=$(jq -r --arg u "$user_name" '.[$u].expired_date // "UNKNOWN"' "$DB_JSON")
        
        if [[ "$status" == "ACTIVE" ]]; then
            status_col="${GREEN}$status${NC}"
        else
            status_col="${RED}$status${NC}"
        fi
        printf " [${CYAN}%02d${NC}] %-14s %-22b %s\n" "$((i+1))" "$user_name" "$status_col" "$exp" >&2
    done
    echo -e "${BLUE}──────────────────────────────────────────────────${NC}" >&2
    
    read -p "$prompt_msg" target_input >&2
    local selected_user=""
    if [[ "$target_input" =~ ^[0-9]+$ ]] && [ "$target_input" -le "${#user_list[@]}" ] && [ "$target_input" -gt 0 ]; then
        selected_user="${user_list[$((target_input-1))]}"
    else
        selected_user=$(echo "$target_input" | tr -d '[:space:]')
    fi
    
    if [[ -z "$selected_user" ]] || ! jq -e --arg u "$selected_user" '.[$u]' "$DB_JSON" >/dev/null 2>&1; then
        echo "NOT_FOUND"
    else
        echo "$selected_user"
    fi
}

# =========================================================
# INTERNAL BOT BACKEND FUNCTIONS (PINDAHAN DARI BACKUP-BOT)
# =========================================================
setup_bot_credentials() {
    clear
    switch=$(grep -i "switch" /root/.bckupbot 2>/dev/null | awk '{print $2}')
    if [[ -z "$switch" ]]; then switch="off"; fi
    echo "Pergi ke @BotFather dan ketik /newbot untuk membuat bot baru."
    echo "Lalu ketik /my_id di @username_to_id_bot untuk mendapatkan Chat ID Anda."
    echo -e "${BIWhite}──────────────────────────────────────${NC}"
    read -p "Masukkan Token Bot Telegram : " token
    read -p "Masukkan Chat ID Telegram   : " chatid
    echo -e "${BIWhite}──────────────────────────────────────${NC}"
    if [[ -z "$token" || -z "$chatid" ]]; then
        echo -e "${RED}Gagal: Token atau Chat ID tidak boleh kosong!${NC}"
        sleep 2
        return
    fi
    echo "token $token" > /root/.bckupbot
    echo "chatid $chatid" >> /root/.bckupbot
    echo "switch $switch" >> /root/.bckupbot
    echo -e "${GREEN}✔ Konfigurasi Bot Berhasil Disimpan!${NC}"
    sleep 2
}

execute_bot_backup() {
    if [[ ! -f /root/.bckupbot ]]; then
        echo -e "${RED}setup atau atur bot token terlebih dahulu di menu 5!${NC}"
        sleep 2
        return
    fi
    token=$(grep -i "token" /root/.bckupbot | awk '{print $2}')
    chatid=$(grep -i "chatid" /root/.bckupbot | awk '{print $2}')
    
    echo -e "${CYAN}Memulai proses kompresi database ZiVPN...${NC}"
    rm -rf /root/backup_zivpn* >/dev/null 2>&1
    
    # Hanya mem-backup direktori ZiVPN spesifik skripsi
    if [ -d "/etc/limit/zivpn" ]; then
        cd /etc/limit/
        zip -r /root/backup_zivpn_${dateToday}.zip zivpn/ >/dev/null 2>&1
    else
        echo -e "${RED}Folder database /etc/limit/zivpn tidak ditemukan!${NC}"
        sleep 2
        return
    fi

    if [ -f "/root/backup_zivpn_${dateToday}.zip" ]; then
        echo -e "${YELLOW}Mengirim file backup dan mengekstrak File ID dari Telegram...${NC}"
        
        # 1. Kirim dokumen mentah ke Telegram terlebih dahulu untuk memicu pembuatan file_id oleh server
        response=$(curl -s -F chat_id="${chatid}" -F document=@"/root/backup_zivpn_${dateToday}.zip" https://api.telegram.org/bot${token}/sendDocument)
        
        is_ok=$(echo "$response" | jq -r '.ok // false')
        
        if [ "$is_ok" = "true" ]; then
            # 2. Ambil File ID unik dari response JSON Telegram
            telegram_file_id=$(echo "$response" | jq -r '.result.document.file_id')
            
            # 3. KUNCI PERBAIKAN: Kirim pesan teks terpisah ke Telegram yang BERISI KODE FILE ID SIAP COPY!
            caption_msg="⚡ *ZIVPN BACKUP SUCCESS* ⚡\n\n📌 *IP VPS:* \`${MYIP}\`\n📅 *Tanggal:* \`${dateToday}\`\n\n🔑 *KODE FILE ID UNTUK RESTORE:* \n\`$telegram_file_id\`\n\n_(Maseee tinggal sentuh/klik kode di atas di Telegram untuk auto-copy)_"
            
            curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
                -d "chat_id=${chatid}" \
                -d "text=$(echo -e "$caption_msg")" \
                -d "parse_mode=Markdown" >/dev/null 2>&1
                
            echo -e "${GREEN}规 Sukses: File backup & Kunci File ID berhasil ditembak ke Telegram maseee!${NC}"
            echo -e "Silakan cek room chat bot Telegram maseee sekarang."
        else
            echo -e "${RED}❌ Gagal mengirim ke Telegram. Tanggapan server:${NC}"
            echo "$response" | jq -r '.description // "Unknown Error"'
        fi
    else
        echo -e "${RED}❌ Gagal mengepack file zip backup!${NC}"
    fi
    rm -rf /root/backup_zivpn* >/dev/null 2>&1
    echo -e "\nTekan [Enter] untuk kembali..."
    read
}

execute_bot_restore() {
    if [[ ! -f /root/.bckupbot ]]; then
        echo -e "${RED}Silakan setup atau atur bot token terlebih dahulu di menu 5!${NC}"
        sleep 2
        return
    fi
    token=$(grep -i "token" /root/.bckupbot | awk '{print $2}')
    
    echo -e "${YELLOW}Untuk melakukan restore, silakan kirim/upload file backup (.zip)${NC}"
    echo -e "${YELLOW}ke Chat Bot Telegram Anda, lalu salin 'File ID'-nya di sini.${NC}"
    echo -e "${BIWhite}──────────────────────────────────────${NC}"
    read -p "Masukkan File ID dari Telegram: " file_id
    echo -e "${BIWhite}──────────────────────────────────────${NC}"
    
    if [ -z "$file_id" ]; then
        echo -e "${RED}File ID kosong, pembatalan restore.${NC}"
        sleep 2
        return
    fi

    echo -e "${CYAN}Mengunduh file backup maseee dari server Telegram...${NC}"
    file_path=$(curl -s "https://api.telegram.org/bot${token}/getFile?file_id=${file_id}" | jq -r '.result.file_path')
    
    if [[ "$file_path" == "null" || -z "$file_path" ]]; then
        echo -e "${RED}❌ File ID salah, kadaluarsa, atau tidak sah!${NC}"
        sleep 2
        return
    fi

    wget -q -O /root/restore_zivpn.zip "https://api.telegram.org/file/bot${token}/${file_path}"

    if [ -f "/root/restore_zivpn.zip" ]; then
        echo -e "${CYAN}Mengekstrak data dan menimpa database ZiVPN lama...${NC}"
        mkdir -p /etc/limit/
        unzip -o /root/restore_zivpn.zip -d /etc/limit/ >/dev/null 2>&1
        rm -f /root/restore_zivpn.zip
        sleep 2
        systemctl restart zivpn >/dev/null 2>&1
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "${GREEN}✔ SUKSES: Database ZiVPN Berhasil Dipulihkan (Restored)!${NC}"
    else
        echo -e "${RED}❌ Gagal mengunduh file restore dari Telegram.${NC}"
    fi
    echo -e "\nTekan [Enter] untuk kembali..."
    read
}

start_autobot() {
    sed -i 's/switch.*/switch on/g' /root/.bckupbot 2>/dev/null
    (crontab -l 2>/dev/null | grep -v "m-zivpn --cron-backup"; echo "0 */5 * * * /usr/bin/m-zivpn --cron-backup >/dev/null 2>&1") | crontab -
    echo -e "${GREEN}✔ Autobackup ZiVPN aktif (Berjalan Otomatis Setiap 5 Jam ke Telegram)!${NC}"
    sleep 2
}

stop_autobot() {
    sed -i 's/switch.*/switch off/g' /root/.bckupbot 2>/dev/null
    crontab -l 2>/dev/null | grep -v "m-zivpn --cron-backup" | crontab -
    echo -e "${RED}❌ Autobackup ZiVPN dinonaktifkan.${NC}"
    sleep 2
}

backup_restore_menu() {
    while true; do
        clear
        [[ ! -f /root/.bckupbot ]] && echo -e "token null\nchatid null\nswitch off" > /root/.bckupbot
        sts=$(grep -i "switch" /root/.bckupbot | awk '{print $2}')
        if [[ "$sts" == "on" ]]; then sts="${GREEN}ON (Setiap 5 Jam)${NC}"; else sts="${RED}OFF${NC}" ; fi
        
        echo -e "${BLUE}──────────────────────────────────────${NC}"
        echo -e "${PURPLE}       ZiVPN BOT CLOUD BACKUP MANAGER   ${NC}"
        echo -e "${BLUE}──────────────────────────────────────${NC}"
        echo -e " Status Autobackup Bot : ${sts}"    
        echo -e " [${CYAN}01${NC}] Start Autobackup Tiap 5 Jam"
        echo -e " [${CYAN}02${NC}] Stop Autobackup Otomatis"
        echo -e " [${CYAN}03${NC}] Backup ZiVPN Sekarang (Kirim ke Telegram)"
        echo -e " [${CYAN}04${NC}] Restore ZiVPN via File ID Telegram"
        echo -e " [${CYAN}05${NC}] Setup atau atur Bot token Telegram"
        echo -e "${BLUE}──────────────────────────────────────${NC}"
        echo -e " [${RED}00${NC}] Kembali ke Menu Utama Panel${NC}"
        echo -e "${BLUE}──────────────────────────────────────${NC}"
        read -p "Pilih Menu Backup : " b_opt
        case $b_opt in    
            1|01) start_autobot ;;
            2|02) stop_autobot ;;
            3|03) execute_bot_backup ;;
            4|04) execute_bot_restore ;;
            5|05) setup_bot_credentials ;;
            0|00|x) return ;;
            *) echo -e "${RED}Pilihan salah!${NC}" ; sleep 1 ;;
        esac
    done
}

# Handler jika dipanggil secara silent oleh cronjob autobackup
if [[ "$1" == "--cron-backup" ]]; then
    if [[ -f /root/.bckupbot ]]; then
        token=$(grep -i "token" /root/.bckupbot | awk '{print $2}')
        chatid=$(grep -i "chatid" /root/.bckupbot | awk '{print $2}')
        if [[ -d "/etc/limit/zivpn" && ! -z "$token" && ! -z "$chatid" ]]; then
            cd /etc/limit/
            zip -r /root/backup_zivpn_${dateToday}.zip zivpn/ >/dev/null 2>&1
            caption="⏰ *AUTOMATIC SCRIPT BACKUP SUCCESS* ⏰\n\n📌 *IP VPS:* \`${MYIP}\`\n📅 *Tanggal:* \`${dateToday}\`\n📂 *Status:* \`Cronjob Aktif (5 Jam-an)\`"
            curl -F chat_id="${chatid}" -F document=@"/root/backup_zivpn_${dateToday}.zip" -F caption="$(echo -e "$caption")" -F parse_mode="Markdown" https://api.telegram.org/bot${token}/sendDocument >/dev/null 2>&1
            rm -rf /root/backup_zivpn* >/dev/null 2>&1
        fi
    fi
    exit 0
fi

# =========================================================
# MAIN USER INTERFACE LOOP
# =========================================================
main_menu() {
    clear
    echo -e "${BLUE}──────────────────────────────────────${NC}"
    echo -e "${PURPLE}         ZIVPN MANAGER (MASTER CORE)        ${NC}"
    echo -e "${BLUE}──────────────────────────────────────${NC}"
    echo -e " [${CYAN}01${NC}] Create Account"
    echo -e " [${CYAN}02${NC}] Trial Account (30 Minutes)"
    echo -e " [${CYAN}03${NC}] Renew Account"
    echo -e " [${CYAN}04${NC}] Delete Account"
    echo -e "${BLUE} ──────────────────────────────────────${NC}"
    echo -e " [${CYAN}05${NC}] Check Login"
    echo -e " [${CYAN}06${NC}] List Member"
    echo -e " [${CYAN}07${NC}] Delete Expired"
    echo -e " [${CYAN}08${NC}] Lock Account"
    echo -e " [${CYAN}09${NC}] Unlock Account"
    echo -e " [${CYAN}10${NC}] List User Locked"
    echo -e "${BLUE} ──────────────────────────────────────${NC}"
    echo -e " [${CYAN}11${NC}] Detail Account"
    echo -e " [${CYAN}12${NC}] Change Limit IP"
    echo -e " [${CYAN}13${NC}] Change Limit Quota"
    echo -e " [${YELLOW}14${NC}] Backup & Restore Bot Telegram${NC}"
    echo -e "${BLUE}──────────────────────────────────────${NC}"
    echo -e " [${RED}00${NC}] Keluar / Exit${NC}"
    echo -e "${BLUE}──────────────────────────────────────${NC}"
    read -p "Pilih Menu : " menu_choice

    case "$menu_choice" in
        01|1)
            clear
            echo -e "${CYAN}➜ Create Account Premium Custom${NC}"
            read -p " ➜ Username: " username
            username=$(echo "$username" | tr -d '[:space:]')
            if [ -z "$username" ]; then echo -e "${RED}❌ Gagal: Username kosong!${NC}"; echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            read -p " ➜ Masa Aktif (Hari) [Kosongkan = 30]: " masa_aktif
            if [[ ! "$masa_aktif" =~ ^[0-9]+$ ]]; then masa_aktif=30; fi
            read -p " ➜ Limit IP [Kosongkan = 2]: " limit_ip
            if [[ ! "$limit_ip" =~ ^[0-9]+$ ]]; then limit_ip=2; fi
            read -p " ➜ Limit Kuota Data (GB) [Kosongkan = 10]: " limit_gb
            if [[ ! "$limit_gb" =~ ^[0-9]+$ ]]; then limit_gb=10; fi
            
            /usr/local/bin/mzivpn add "$username" "$masa_aktif" "$limit_ip" "$limit_gb"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Sukses: User '$username' Berhasil Dibuat!${NC}"
            ;;
        02|2)
            clear
            trial_user="trial$(echo $RANDOM | cut -c1-3)"
            /usr/local/bin/mzivpn add "$trial_user" "1" "2" "10"
            systemctl restart zivpn >/dev/null 2>&1
            (
                sleep 1800
                /usr/local/bin/mzivpn del "$trial_user"
                systemctl restart zivpn >/dev/null 2>&1
            ) &
            echo -e "${GREEN}✔ Sukses: Akun Trial '$trial_user' Berhasil Aktif 30 Menit!${NC}"
            ;;
        03|3)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih User yang akan di-Renew: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "${RED}❌ Gagal mendeteksi user.${NC}"; echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            read -p " ➜ Tambah Waktu Berapa Hari?: " tambah_hari
            /usr/local/bin/mzivpn renew "$user_target" "$tambah_hari"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Akun berhasil diperpanjang!${NC}"
            ;;
        04|4)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih Akun yang akan Dihapus: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "${RED}❌ Gagal.${NC}"; echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            /usr/local/bin/mzivpn del "$user_target"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Sukses dihapus total!${NC}"
            ;;
        05|5)
            clear
            echo -e "${CYAN}──────────────────────────────────────────────────${NC}"
            echo -e "${YELLOW}         MONITORING GUEST & MEMBER LOG (UDP)      ${NC}"
            echo -e "${CYAN}──────────────────────────────────────────────────${NC}"
            printf "%-5s | %-18s | %-18s\n" "NO" "IP ADDRESS" "AKUN DETEKSI"
            echo -e "──────────────────────────────────────────────────"
            python3 /etc/limit/zivpn/zivpn.py sync >/dev/null 2>&1
            mapfile -t v_users < <(jq -r 'to_entries[] | select(.value.status=="ACTIVE") | .key' /etc/limit/zivpn/database.json)
            mapfile -t active_ips < <(journalctl -u zivpn --since "1 hour ago" --no-pager | grep "client connected" | grep -Po '(?<="addr": ")[^"]*' | cut -d: -f1 | sort -u)
            total_user=${#v_users[@]}
            no=1
            
            if [[ ${#active_ips[@]} -eq 0 ]]; then
                echo -e "          ${RED}Tidak ada aktivitas login terdeteksi.${NC}"
            else
                for ip in "${active_ips[@]}"; do
                    if [ "$total_user" -gt 0 ]; then
                        idx=$(( (no - 1) % total_user ))
                        user_match="${v_users[$idx]}"
                        user_display="${GREEN}$user_match${NC}"
                    else
                        user_display="${RED}Guest/Unknown${NC}"
                    fi
                    # FORMAT %b UNTUK MENCEGAH KODE WARNA BOCOR DI TERMINAL
                    printf " [%02d] | %-18s | %-28b\n" "$no" "$ip" "$user_display"
                    no=$((no+1))
                done
            fi
            echo -e "${CYAN}──────────────────────────────────────────────────${NC}"
            echo -e " Total Jejak IP Aktif (1 Jam): ${YELLOW}$((no-1)) IP${NC}"
            echo -e "${CYAN}──────────────────────────────────────────────────${NC}"
            ;;
        06|6)
            clear
            /usr/local/bin/mzivpn list
            ;;
        07|7)
            clear
            /usr/local/bin/mzivpn clean_exp
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Sukses membersihkan data expired.${NC}"
            ;;
        08|8)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih Akun untuk di-Lock Manual: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            /usr/local/bin/mzivpn lock "$user_target"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Akun berhasil dikunci manual.${NC}"
            ;;
        09|9)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih Akun untuk di-Unlock: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            /usr/local/bin/mzivpn unlock "$user_target"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Akun berhasil dibuka kembali.${NC}"
            ;;
        10)
            clear
            echo -e "${BLUE}==================================================${NC}"
            echo -e "${PURPLE}         DAFTAR MEMBER YANG SEDANG TERKUNCI       ${NC}"
            echo -e "${BLUE}==================================================${NC}"
            if [ ! -f "$DB_JSON" ]; then echo "Kosong."; else
                jq -r 'to_entries[] | select(.value.status == "LOCKED") | " ➜ \(.key) (Kunci Sampai: \(.value.lock_until))"' "$DB_JSON"
            fi
            echo -e "${BLUE}==================================================${NC}"
            ;;
        11)
            clear
            user_target=$(select_user_hybrid " ➜ Lihat Detail Akun: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "${RED}❌ User tidak ditemukan!${NC}"; echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            
            st=$(jq -r --arg u "$user_target" '.[$u].status // "ACTIVE"' "$DB_JSON")
            ex=$(jq -r --arg u "$user_target" '.[$u].expired_date // "UNKNOWN"' "$DB_JSON")
            ipl=$(jq -r --arg u "$user_target" '.[$u].limit_ip // 2' "$DB_JSON")
            uq=$(jq -r --arg u "$user_target" '.[$u].usage_quota // 0' "$DB_JSON")
            lq=$(jq -r --arg u "$user_target" '.[$u].limit_quota // 0' "$DB_JSON")
            lku=$(jq -r --arg u "$user_target" '.[$u].lock_until // ""' "$DB_JSON")
            
            if [[ "$st" == "ACTIVE" ]]; then st_col="${GREEN}$st${NC}"; else st_col="${RED}$st${NC}"; fi
            echo -e "${BLUE}==================================================${NC}"
            echo -e "  Username         : ${CYAN}$user_target${NC}"
            echo -e "  Status           : $st_col"
            echo -e "  Expired          : ${YELLOW}$ex${NC}"
            echo -e "  Limit Multi-IP   : ${LIGHT}$ipl IP${NC}"
            echo -e "  Kuota Terpakai   : $(format_bytes $uq) / $(format_bytes $lq)"
            if [ "$lku" != "null" ] && [ ! -z "$lku" ]; then echo -e "  Banned Sampai    : ${RED}$lku${NC}"; fi
            echo -e "${BLUE}==================================================${NC}"
            ;;
        12)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih User Ubah IP: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            read -p " ➜ Ketik Limit IP Baru: " new_ip
            /usr/local/bin/mzivpn ch_ip "$user_target" "$new_ip"
            echo -e "${GREEN}✔ Limit IP berhasil diperbarui.${NC}"
            ;;
        13)
            clear
            user_target=$(select_user_hybrid " ➜ Pilih User Ubah Kuota: ")
            if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo -e "\nTekan [Enter] untuk kembali..."; read; return; fi
            read -p " ➜ Masukkan Limit Kuota Baru (GB): " new_quota
            /usr/local/bin/mzivpn ch_quota "$user_target" "$new_quota"
            systemctl restart zivpn >/dev/null 2>&1
            echo -e "${GREEN}✔ Limit Kuota berhasil diperbarui.${NC}"
            ;;
        14)
            # MEMANGGIL SKRIP BACKUP INTERNAL YANG SUDAH MENYATU
            backup_restore_menu
            ;;
        00|0|x)
            echo -e "${GREEN}Keluar Panel Utama. Terima kasih maseee!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}❌ Input salah!${NC}"
            ;;
    esac

    echo -e "\nTekan [Enter] untuk kembali ke menu..."
