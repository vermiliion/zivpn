#!/bin/bash
# =========================================================
# PREMIUM INTERACTIVE INTERFACE MENU MANAGER V4 HYBRID
# Location: m-zivpn (Simpan & upload ke GitHub maseee)
# =========================================================

DB_JSON="/etc/limit/zivpn/database.json"

format_bytes() {
    local bytes=$1
    if [ -z "$bytes" ] || [ "$bytes" -lt 0 ] 2>/dev/null; then bytes=0; fi
    if (( bytes >= 1073741824 )); then
        echo -e "$(printf "%.2f" $(echo "scale=2; $bytes/1073741824" | bc)) GB"
    elif (( bytes >= 1048576 )); then
        echo -e "$(printf "%.2f" $(echo "scale=2; $bytes/1048576" | bc)) MB"
    else
        echo -e "${bytes} Bytes"
    fi
}

select_user_hybrid() {
    local prompt_msg=$1
    if [ ! -f "$DB_JSON" ] || [ "$(jq 'keys | length' $DB_JSON 2>/dev/null)" -eq 0 ]; then
        echo "EMPTY"; return
    fi
    mapfile -t user_list < <(jq -r 'keys[]' "$DB_JSON" 2>/dev/null)
    echo -e "No.  Username       Status        Expired"
    echo -e "в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
    for i in "${!user_list[@]}"; do
        status=$(jq -r --arg u "${user_list[$i]}" '.[$u].status' "$DB_JSON")
        exp=$(jq -r --arg u "${user_list[$i]}" '.[$u].expired_date' "$DB_JSON")
        if [[ "$status" == "ACTIVE" ]]; then
            status_col="\033[1;32m$status\033[0m"
        else
            status_col="\033[1;31m$status\033[0m"
        fi
        printf " [%02d] %-14s %-22b %s\n" "$((i+1))" "${user_list[$i]}" "$status_col" "$exp"
    done
    echo -e "в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
    read -p "$prompt_msg" target_input
    local selected_user=""
    if [[ "$target_input" =~ ^[0-9]+$ ]] && [ "$target_input" -le "${#user_list[@]}" ] && [ "$target_input" -gt 0 ]; then
        selected_user="${user_list[$((target_input-1))]}"
    else
        selected_user=$(echo "$target_input" | tr -d '[:space:]')
    fi
    if [[ -z "$selected_user" ]] || ! jq -e --arg u "$selected_user" '.[$u]' "$DB_JSON" >/dev/null 2>&1; then
        echo "NOT_FOUND"
    else
        echo "$selected_user"
    fi
}

clear
echo -e "\033[1;36mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
echo -e "\033[1;33m          MENU UTAMA PREMIUM ZIVPN MANAGER        \033[0m"
echo -e "\033[1;36mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
echo -e " \033[1;33m[01]\033[0m Buat Akun Premium Kustom (Add Advanced User)"
echo -e " \033[1;33m[02]\033[0m Buat Akun Trial (Default 1 Hari, 2 IP, 10GB)"
echo -e " \033[1;33m[03]\033[0m Perpanjang Masa Aktif Akun (Renew User)"
echo -e " \033[1;33m[04]\033[0m Hapus Akun Terdaftar (Delete User)"
echo -e "\033[1;36m в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
echo -e " \033[1;33m[05]\033[0m Tampilkan Seluruh Member (List Users)"
echo -e " \033[1;33m[06]\033[0m Detail Informasi Akun (Cek Kuota & Limit IP)"
echo -e " \033[1;33m[07]\033[0m Ubah Batasan Multi-IP Akun (Change Limit IP)"
echo -e " \033[1;33m[08]\033[0m Ubah Batasan Kuota Data (Change Limit Quota)"
echo -e " \033[1;33m[09]\033[0m Kunci / Blokir Akun Sementara (Lock Account)"
echo -e " \033[1;33m[10]\033[0m Buka Kunci / Unbanned Akun (Unlock Account)"
echo -e " \033[1;33m[11]\033[0m Bersihkan Semua Akun Expired (Clear Expired)"
echo -e " \033[1;33m[12]\033[0m Cek Status Service Core ZIVPN"
echo -e " \033[1;33m[00]\033[0m Keluar Aplikasi (Exit)"
echo -e "\033[1;36mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
read -p " Pilihan maseee [01-12] : " menu_choice

case "$menu_choice" in
    01|1)
        clear
        echo -e "\033[1;36m==================================================\033[0m"
        echo -e "\033[1;33m             BUAT AKUN PREMIUM CUSTOM             \033[0m"
        echo -e "\033[1;36m==================================================\033[0m"
        read -p " вћњ Masukkan Username Baru : " username
        username=$(echo "$username" | tr -d '[:space:]')
        if [ -z "$username" ]; then echo "вќЊ Gagal: Username kosong!"; exit 1; fi
        
        read -p " вћњ Durasi Masa Aktif (Hari): " masa_aktif
        if [[ ! "$masa_aktif" =~ ^[0-9]+$ ]]; then masa_aktif=30; fi
        
        read -p " вћњ Batasan Multi-IP (Device): " limit_ip
        if [[ ! "$limit_ip" =~ ^[0-9]+$ ]]; then limit_ip=2; fi
        
        read -p " вћњ Total Limit Kuota Data (GB): " limit_gb
        if [[ ! "$limit_gb" =~ ^[0-9]+$ ]]; then limit_gb=10; fi
        
        /usr/local/bin/mzivpn add "$username" "$masa_aktif" "$limit_ip" "$limit_gb"
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "\033[1;92mвњ” Sukses: User '$username' Aktif $masa_aktif Hari, Limit $limit_ip IP, Kuota $limit_gb GB!\033[0m"
        ;;
        
    02|2)
        clear
        trial_user="trial$(echo $RANDOM | cut -c1-3)"
        /usr/local/bin/mzivpn add "$trial_user" "1" "2" "10"
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "\033[1;92mвњ” Akun Trial Dibuat: '$trial_user' (1 Hari, 2 IP, 10GB Data)!\033[0m"
        ;;
        
    03|3)
        clear
        user_target=$(select_user_hybrid " вћњ Masukkan Nomor atau Nama Akun: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then echo "вќЊ Masalah Database/User."; exit 1; fi
        read -p " вћњ Tambah Waktu (Hari): " tambah_hari
        /usr/local/bin/mzivpn renew "$user_target" "$tambah_hari"
        systemctl restart zivpn >/dev/null 2>&1
        echo "вњ” Akun diperpanjang!"
        ;;
        
    04|4)
        clear
        user_target=$(select_user_hybrid " вћњ Hapus Akun Nomor/Nama: ")
        /usr/local/bin/mzivpn del "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        echo "вњ” Dicabut!"
        ;;
        
    05|5)
        clear
        if [ ! -f "$DB_JSON" ] || [ "$(jq 'keys | length' $DB_JSON 2>/dev/null)" -eq 0 ]; then echo "Kosong."; else
            printf "%-3s %-15s %-12s %-12s %-8s\n" "No" "Username" "Status" "Expired" "Limit IP"
            echo "--------------------------------------------------"
            mapfile -t users < <(jq -r 'keys[]' "$DB_JSON"); c=1
            for u in "${users[@]}"; do
                st=$(jq -r --arg u "$u" '.[$u].status' "$DB_JSON")
                ex=$(jq -r --arg u "$u" '.[$u].expired_date' "$DB_JSON")
                ipl=$(jq -r --arg u "$u" '.[$u].limit_ip' "$DB_JSON")
                if [[ "$st" == "ACTIVE" ]]; then st_col="\033[1;32m$st\033[0m"; else st_col="\033[1;31m$st\033[0m"; fi
                printf "[%02d] %-15s %-21b %-12s %-8s\n" "$c" "$u" "$st_col" "$ex" "$ipl"; c=$((c+1))
            done
        fi
        ;;
        
    06|6)
        clear
        user_target=$(select_user_hybrid " вћњ Detail User Nomor/Nama: ")
        if [[ "$user_target" == "EMPTY" || "$user_target" == "NOT_FOUND" ]]; then exit 1; fi
        st=$(jq -r --arg u "$user_target" '.[$u].status' "$DB_JSON")
        ex=$(jq -r --arg u "$user_target" '.[$u].expired_date' "$DB_JSON")
        ipl=$(jq -r --arg u "$user_target" '.[$u].limit_ip' "$DB_JSON")
        uq=$(jq -r --arg u "$user_target" '.[$u].usage_quota' "$DB_JSON")
        lq=$(jq -r --arg u "$user_target" '.[$u].limit_quota' "$DB_JSON")
        if [[ "$st" == "ACTIVE" ]]; then st_col="\033[1;32m$st\033[0m"; else st_col="\033[1;31m$st\033[0m"; fi
        echo "=================================================="
        echo "  Username         : $user_target"
        echo "  Status           : $st_col"
        echo "  Expired          : $ex"
        echo "  Limit Multi-IP   : $ipl IP"
        echo "  Kuota Terpakai   : $(format_bytes $uq) / $(format_bytes $lq)"
        echo "=================================================="
        ;;
        
    07)
        clear
        user_target=$(select_user_hybrid " вћњ Pilih User: ")
        read -p " вћњ Limit IP Baru: " new_ip
        /usr/local/bin/mzivpn ch_ip "$user_target" "$new_ip"
        ;;
    08)
        clear
        user_target=$(select_user_hybrid " вћњ Pilih User: ")
        read -p " вћњ Kuota Baru (GB): " new_quota
        /usr/local/bin/mzivpn ch_quota "$user_target" "$new_quota"
        systemctl restart zivpn >/dev/null 2>&1
        ;;
    09)
        clear
        user_target=$(select_user_hybrid " вћњ Lock User: ")
        /usr/local/bin/mzivpn lock "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        ;;
    10)
        clear
        user_target=$(select_user_hybrid " вћњ Unlock User: ")
        /usr/local/bin/mzivpn unlock "$user_target"
        systemctl restart zivpn >/dev/null 2>&1
        ;;
    11)
        clear
        /usr/local/bin/mzivpn clean_exp
        systemctl restart zivpn >/dev/null 2>&1
        ;;
    12)
        clear
        systemctl status zivpn
        ;;
    00|0)
        exit 0
        ;;
    *)
        echo "вќЊ Salah input!"
        exit 1
        ;;
esac
